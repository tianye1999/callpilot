ADMIN_TOKEN=replace-with-a-random-admin-token
LIVEKIT_API_KEY=replace-with-livekit-api-key
LIVEKIT_API_SECRET=replace-with-livekit-api-secret
CONTENT_READ_ENABLED=false
APP_REVIEW_PAIRING_ENABLED=false
VOIP_PUSH_ENABLED=false
# Required only when VOIP_PUSH_ENABLED=true. Store real values with `wrangler secret put`.
APNS_TEAM_ID=replace-with-apple-team-id
APNS_KEY_ID=replace-with-apns-key-id
APNS_PRIVATE_KEY=replace-with-apns-p8-private-key
APNS_BUNDLE_ID=ai.bondings.callpilot
PUSH_TOKEN_ENCRYPTION_KEY=replace-with-32-byte-base64url-key
