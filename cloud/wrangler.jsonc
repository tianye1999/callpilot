{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "callpilot-cloud-beta",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-11",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "callpilot-cloud-beta",
      "database_id": "local-placeholder",
      "migrations_dir": "migrations"
    }
  ],
  "durable_objects": {
    "bindings": [
      { "name": "EDGE_ROOMS", "class_name": "EdgeRoom" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["EdgeRoom"] }
  ],
  "vars": {
    "PUBLIC_ORIGIN": "https://dial.bondings.ai",
    "LIVEKIT_URL": "wss://replace-me.livekit.cloud"
  }
}
