# EG25 模组 AT 串口（设备管理器中查看，如 COM3）
MODEM_PORT=COM3
MODEM_BAUD=115200

# 音频模式：nmea=USB NMEA 串口 PCM；uac=USB 声卡
MODEM_AUDIO_MODE=nmea
MODEM_PCM_PORT=COM4
MODEM_PCM_BAUD=921600

# 仅 UAC 声卡模式使用：模组 USB 声卡名称关键字
MODEM_AUDIO_KEYWORD=EG25

# Agent 提供商: qwen | doubao
AGENT_PROVIDER=qwen

# --- 通义千问 (DashScope) ---
DASHSCOPE_API_KEY=sk-xxx
# 实时语音的函数调用（工具）仅 qwen3.5-omni-*-realtime 支持
QWEN_REALTIME_MODEL=qwen3.5-omni-flash-realtime
# qwen3.5-omni 支持的音色：Ethan、Tina 等（不支持旧的 Chelsie）
QWEN_VOICE=Raymond
AGENT_MODEL_NAME=通义千问 Qwen3.5-Omni
AGENT_OUTBOUND_TASK=代表田野主动外呼，对方接起后自然说明来意，并围绕本次目的简短沟通。

# --- 豆包 (火山引擎实时语音) ---
DOUBAO_APP_ID=
DOUBAO_ACCESS_KEY=
DOUBAO_RESOURCE_ID=volc.speech.dialog
DOUBAO_APP_KEY=PlgvMymc7f3tQnJ6
AGENT_MODEL_NAME_DOUBAO=豆包实时语音大模型
