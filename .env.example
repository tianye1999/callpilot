# CallPilot 配置示例（与 src/agentcall/config.py 的 CONFIG_SPECS 注册表对齐）。
# 复制为 .env 后按需修改；所有「面板可编辑」项也可在网页设置面板中直接改。

# ================= Agent =================
# Agent 提供方: qwen | doubao | openai
AGENT_PROVIDER=qwen
# 机主姓名（AI 自我介绍与通话摘要视角；默认空 = 中性称谓「机主」）
OWNER_NAME=
# AI 人设称谓（默认空 = 按 AGENT_LANGUAGE 取「AI 助理」/「AI assistant」）
AGENT_PERSONA=
# AI 通话语言: zh | en —— 决定 AI 打/接电话说什么语言、摘要用什么语言（默认 zh）
AGENT_LANGUAGE=zh
# 外呼默认任务指令（单次外呼可在页面临时覆盖）
AGENT_OUTBOUND_TASK=代表机主主动外呼，对方接起后自然说明来意，并围绕本次目的简短沟通。

# --- 通义千问 (DashScope) ---
# 必填（qwen 提供方）。留空即可：占位值会骗过启动非空校验，
# 把鉴权错误推迟到第一通电话。申请：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=
# 实时语音的函数调用（工具）仅 qwen3.5-omni-*-realtime 支持
QWEN_REALTIME_MODEL=qwen3.5-omni-flash-realtime
# qwen3.5-omni 支持的音色：Ethan、Tina 等（不支持旧的 Chelsie）
QWEN_VOICE=Raymond
# 模型显示名（/api/meta 与自我介绍用，一般无需改动）
AGENT_MODEL_NAME=Qwen3.5-Omni

# --- 豆包 (火山引擎实时语音) ---
DOUBAO_APP_ID=
DOUBAO_ACCESS_KEY=
# 以下为火山引擎文档给定的固定参数，一般无需改动
DOUBAO_RESOURCE_ID=volc.speech.dialog
DOUBAO_APP_KEY=PlgvMymc7f3tQnJ6
AGENT_MODEL_NAME_DOUBAO=Doubao Realtime

# --- OpenAI (Realtime API) ---
OPENAI_API_KEY=
# 实时模型：默认 gpt-realtime-mini（速度快、性价比高），可改 gpt-realtime
OPENAI_REALTIME_MODEL=gpt-realtime-mini
# 音色：alloy、ash、cedar、coral、marin 等
OPENAI_VOICE=alloy
# Realtime 端点覆写（可选，wss 地址 base，留空 = 直连 wss://api.openai.com/v1/realtime）。
# 仅在用反代 / Azure OpenAI，或所在网络无法直连 OpenAI 时才需要填。
OPENAI_REALTIME_URL=
# 模型显示名（/api/meta 用，一般无需改动）
AGENT_MODEL_NAME_OPENAI=OpenAI Realtime Mini

# ================= 模组 =================
# 模组 AT 串口。macOS 必须写 /tmp/ec20-at（由 scripts/ec20_usb_pty.py 桥提供，
# macOS 没有 Quectel 厂商串口的原生设备）；Windows 用 auto 或在设备管理器查看，如 COM3。
MODEM_PORT=/tmp/ec20-at
# AT 串口波特率（默认: 115200）
MODEM_BAUD=115200
# 音频模式：
#   uac_ffmpeg = macOS 推荐：经 ffmpeg 走 UAC 声卡（PortAudio 打不开 EC20 声卡时用）
#   uac        = USB 声卡（PortAudio/sounddevice；Windows/部分环境可用）
#   nmea       = USB NMEA 串口 PCM【macOS 上会崩溃重枚举 USB，勿用】
MODEM_AUDIO_MODE=uac_ffmpeg
# UAC 声卡名称关键字：macOS UAC 声卡名含 "Interface"；Windows 常为 "EG25"/"EC20"
MODEM_AUDIO_KEYWORD=Interface
# nmea 模式专用 PCM 数据串口与波特率（uac/uac_ffmpeg 模式留空/保持默认即可）
MODEM_PCM_PORT=COM4
MODEM_PCM_BAUD=921600
# 上行发送增益（默认: 1.0）
MODEM_TX_GAIN=1.0

# ================= 通话行为 =================
# 半双工挂尾时长（秒，默认: 0.5）
HALF_DUPLEX_HANGOVER_SECONDS=0.5
# AI 调用挂断工具后的延迟挂断秒数（默认: 4.5，留时间说完告别语）
HANGUP_TOOL_DELAY_SECONDS=4.5
# 外呼最长时长（秒，默认: 150）：LLM 收尾裁判失灵时的最后防线，到点自动道别挂断；0=不限
OUTBOUND_MAX_SECONDS=150
# 通话录音开关（默认: true）
RECORDING_ENABLED=true
# 录音保留天数（默认: 30）
RECORDING_RETENTION_DAYS=30
# 通话结构化摘要开关（默认: true）
SUMMARY_ENABLED=true
# 摘要使用的文本模型（默认: qwen-plus）
SUMMARY_MODEL=qwen-plus

# ================= 本地监听 =================
# 在 Mac 扬声器实时旁听 AI 语音（默认: false）
MONITOR_AI_PLAYBACK=false
# 监听输出设备名（默认空 = 跟随系统默认输出设备；填设备名则按名匹配）
MONITOR_OUTPUT_DEVICE=
# 监听增益：AI 下行（默认: 1.0）；对方上行为窄带低电平信号，需大增益（默认: 8.0）
MONITOR_AI_GAIN=1.0
MONITOR_UPLINK_GAIN=8.0

# ================= 白名单与节流 =================
# 外呼白名单：逗号分隔，支持前缀通配（如 138*,10086）；留空 = 全部放行
DIAL_WHITELIST=
# 连续拨号间隔（秒，默认: 5.0）
DIAL_INTERVAL_SECONDS=5.0
# 发短信目标限制为「只能回复已联系过的号码」（来过电/发过短信/当前通话对端），
# 无需配置，见 src/agentcall/contacts.py。

# ================= 连接管理 =================
# Qwen 连接预热：提前建好 TLS 连接，降低首通接听延迟（默认: true）
QWEN_PREWARM=true
# 通话中断线的最大重连次数（默认: 2）
QWEN_RECONNECT_MAX=2
# OpenAI 通话中断线的最大重连次数（默认: 2）
OPENAI_RECONNECT_MAX=2
