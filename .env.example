# CallPilot 配置示例（与 src/agentcall/config.py 的 CONFIG_SPECS 注册表对齐）。
# 复制为 .env 后按需修改；所有「面板可编辑」项也可在网页设置面板中直接改。

# ================= Agent =================
# Agent 提供方: qwen | doubao (experimental) | openai
AGENT_PROVIDER=qwen
# 机主姓名（AI 自我介绍与通话摘要视角；默认空 = 中性称谓「机主」）
OWNER_NAME=
# AI 人设称谓（默认空 = 按 AGENT_LANGUAGE 取「AI 助理」/「AI assistant」）
AGENT_PERSONA=
# 语音风格描述（如"语速稍慢、亲切自然"）；并入系统提示，qwen/openai 两链路生效。默认空
VOICE_STYLE=
# AI 通话语言: zh | en —— 决定 AI 打/接电话说什么语言、摘要用什么语言（默认 zh）
AGENT_LANGUAGE=zh
# 外呼默认任务指令（单次外呼可在页面临时覆盖）
AGENT_OUTBOUND_TASK=代表机主主动外呼，对方接起后自然说明来意，并围绕本次目的简短沟通。
# 拨号前按号码+事项生成本通场景与开场策略（默认 true；失败自动回退模板）
PROMPT_GEN_ENABLED=true
# 动态场景提示词模型：留空=按提供方默认（qwen→qwen-plus，openai→gpt-4o-mini）
PROMPT_GEN_MODEL=
# 动态场景提示词请求超时 / 接通后等待秒数（调试项，一般无需改动）
PROMPT_GEN_TIMEOUT=5.0
PROMPT_GEN_WAIT_SECONDS=3.0
# 预调教任务库：拨号前优先查本地 JSON 里的 (号码+任务) 场景；命中则跳过动态生成。
# 文件留空 = data/number_profiles.json；格式见 data/number_profiles.example.json
NUMBER_PROFILES_ENABLED=true
NUMBER_PROFILES_FILE=
# 三段式 local provider（AGENT_PROVIDER=local）的文本 LLM 脑：默认 qwen-plus
# （复用 DASHSCOPE_API_KEY）。音频（VAD/STT/TTS）全在本机跑，只有转写文本上云。
# 先装依赖 pip install 'callpilot[local]'，再下载模型：
#   .venv/bin/python -m agentcall.local_models
LOCAL_LLM_MODEL=qwen-plus
# 手动应答控制（qwen only，默认 false）：保留 server VAD 转写，但由本地静默合并定时触发回复，
# 抑制对连播 IVR 的逐段抢答。设 true 启用（适合"连续念长菜单"型 IVR）。
# 真机标定（2026-07-10，6 通拨 10000）：IVR 连播段间隙 p90=2.4s——启用时建议
# MANUAL_RESPONSE_SILENCE_MS=2500 才能把连播合并成一轮；代价是真人对话每轮慢 ~2.5s，
# 故保持默认关、按场景手动开。
MANUAL_RESPONSE_CONTROL=false
# 静默超过该窗口才触发一次手动回复；连续转写会重置窗口（默认 1000ms）
MANUAL_RESPONSE_SILENCE_MS=1000
# 连续播报超过该累计等待也强制触发一次回复，避免永远插不进话（默认 8000ms）
MANUAL_RESPONSE_MAX_WAIT_MS=8000

# --- 通义千问 (DashScope) ---
# 必填（qwen 提供方）。留空即可：占位值会骗过启动非空校验，
# 把鉴权错误推迟到第一通电话。申请：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=
# 实时语音的函数调用（工具）仅 qwen3.5-omni-*-realtime 支持
QWEN_REALTIME_MODEL=qwen3.5-omni-flash-realtime
# qwen3.5-omni 支持的音色：Ethan、Tina 等（不支持旧的 Chelsie）
QWEN_VOICE=Raymond
# 模型显示名（/api/meta 与自我介绍用，一般无需改动）
AGENT_MODEL_NAME=Qwen3.5-Omni

# --- 豆包 (火山引擎实时语音，experimental；外呼可能不出声) ---
DOUBAO_APP_ID=
DOUBAO_ACCESS_KEY=
# 以下为火山引擎文档给定的固定参数，一般无需改动
DOUBAO_RESOURCE_ID=volc.speech.dialog
DOUBAO_APP_KEY=PlgvMymc7f3tQnJ6
AGENT_MODEL_NAME_DOUBAO=Doubao Realtime

# --- OpenAI (Realtime API) ---
OPENAI_API_KEY=
# 实时模型：默认 gpt-realtime-2.1-mini（电话链路延迟优先，建议先用它）。
# 可选：gpt-realtime-2.1-mini | gpt-realtime-2.1 | gpt-realtime-2 | gpt-realtime | gpt-realtime-mini
OPENAI_REALTIME_MODEL=gpt-realtime-2.1-mini
# 音色：alloy、ash、cedar、coral、marin 等
OPENAI_VOICE=alloy
# Realtime 端点覆写（可选，wss 地址 base，留空 = 直连 wss://api.openai.com/v1/realtime）。
# 仅在用反代 / Azure OpenAI，或所在网络无法直连 OpenAI 时才需要填。
OPENAI_REALTIME_URL=
# 模型显示名（/api/meta 用，一般无需改动）
AGENT_MODEL_NAME_OPENAI=OpenAI Realtime

# ================= 模组 =================
# 模组 AT 串口。macOS 必须写 /tmp/ec20-at（由 scripts/ec20_usb_pty.py 桥提供，
# macOS 没有 Quectel 厂商串口的原生设备）；Windows 用 auto 或在设备管理器查看，如 COM3。
MODEM_PORT=/tmp/ec20-at
# AT 串口波特率（默认: 115200）
MODEM_BAUD=115200
# 音频模式：
#   uac_ffmpeg = macOS 推荐：经 ffmpeg 走 UAC 声卡（PortAudio 打不开 EC20 声卡时用）
#   uac        = USB 声卡（PortAudio/sounddevice；Windows/部分环境可用）
#   nmea       = USB NMEA 串口 PCM【macOS 上会崩溃重枚举 USB，勿用】
MODEM_AUDIO_MODE=uac_ffmpeg
# UAC 声卡名称关键字：macOS UAC 声卡名含 "Interface"；Windows 常为 "EG25"/"EC20"
MODEM_AUDIO_KEYWORD=Interface
# nmea 模式专用 PCM 数据串口与波特率（uac/uac_ffmpeg 模式留空/保持默认即可）
MODEM_PCM_PORT=COM4
MODEM_PCM_BAUD=921600
# 上行发送增益（默认: 1.0）
MODEM_TX_GAIN=1.0

# ================= 通话行为 =================
# 半双工挂尾时长（秒，默认: 0.5）
HALF_DUPLEX_HANGOVER_SECONDS=0.5
# AI 调用挂断工具后的延迟挂断秒数（默认: 4.5，留时间说完告别语）
HANGUP_TOOL_DELAY_SECONDS=4.5
# DTMF 发送模式：inband=UAC/uac_ffmpeg 带内双音；qvts=AT+QVTS；both=真机对照双发
DTMF_MODE=inband
# 带内双音标定（#73 真机基线：200ms / 0.5 幅度≈-6dBFS；双音自带前后静音隔离带防混叠）
DTMF_TONE_MS=200
DTMF_TONE_AMPLITUDE=0.5
# AI 下行复读抑制相似度阈值（默认: 0.9；0=关闭）。只比较 AI 自己最近说过的话。
REPEAT_SUPPRESS_SIMILARITY=0.9
# 外呼最长时长（秒，默认: 150）：LLM 收尾裁判失灵时的最后防线，到点自动道别挂断；0=不限
OUTBOUND_MAX_SECONDS=150
# 外呼收尾裁判：接通后首次判断等待与后续判断间隔（隐藏调试项）。
WRAP_UP_JUDGE_GRACE_SECONDS=20.0
WRAP_UP_JUDGE_INTERVAL_SECONDS=15.0
# 通话录音开关（默认: false；首启向导会要求明确选择）
RECORDING_ENABLED=false
# 录音保留天数（默认: 30）
RECORDING_RETENTION_DAYS=30
# 通话结构化摘要开关（默认: true）
SUMMARY_ENABLED=true
# 摘要使用的文本模型（默认: qwen-plus）
SUMMARY_MODEL=qwen-plus

# ================= 本地监听 =================
# 在 Mac 扬声器实时旁听 AI 语音（默认: false）
MONITOR_AI_PLAYBACK=false
# 监听输出设备名（默认空 = 跟随系统默认输出设备；填设备名则按名匹配）
MONITOR_OUTPUT_DEVICE=
# 监听增益：AI 下行（默认: 1.0）；对方上行为窄带低电平信号，需大增益（默认: 8.0）
MONITOR_AI_GAIN=1.0
MONITOR_UPLINK_GAIN=8.0

# ================= 白名单与节流 =================
# 外呼白名单：逗号分隔，支持前缀通配（如 138*,10086）；留空 = 全部放行
DIAL_WHITELIST=
# 连续拨号间隔（秒，默认: 5.0）
DIAL_INTERVAL_SECONDS=5.0
# 短信发送频控（AI 工具与 Web 接口共用，默认每小时 10 条；0=不限）
SMS_RATE_LIMIT_PER_HOUR=10
# 短信目标限制：默认只能回复「已联系过的号码」（来过电/发过短信/已接通外呼）。
# 开发期总开关：置 true 放行发给任意号码（仅本机开发测试用，默认关，勿在生产开启）。
SMS_ALLOW_ANY_TARGET=false
# 收件短信进 app 后删 SIM 上那条，防 SIM 存储满收不到新短信（默认开）
SMS_DELETE_AFTER_INGEST=true
# 收到新短信后转发到邮箱（默认关闭）。开启后短信正文会发送到下面的收件邮箱。
# 公共安装包绝不能内置共享 SMTP 密码；每个部署须填写自己的发件账号/应用密码。
SMS_EMAIL_FORWARD_ENABLED=false
SMS_EMAIL_RECIPIENT=
# SMTP 仅允许加密连接：starttls（常用端口 587）或 ssl（常用端口 465）。
SMS_EMAIL_SMTP_HOST=
SMS_EMAIL_SMTP_PORT=587
SMS_EMAIL_SMTP_SECURITY=starttls
SMS_EMAIL_SMTP_USERNAME=
SMS_EMAIL_SMTP_PASSWORD=
SMS_EMAIL_FROM=
# 是否向模型注册「查询最近短信验证码」工具（默认 true；关闭后模型看不到该工具）
TOOL_QUERY_CODE_ENABLED=true
# 发短信目标限制为「只能回复已联系过的号码」（来过电/发过短信/当前通话对端），
# 无需配置，见 src/agentcall/contacts.py。

# ================= 远程网页拨号 POC =================
# 默认关闭。拨号页通过 LiveKit 数据/媒体通道控制 Edge，不需要把本地管理端口暴露到公网。
REMOTE_WEB_DIALER_ENABLED=false
# 普通 Beta 用户启用公司托管控制面：无需 Cloudflare Tunnel 或本地 LiveKit 密钥。
REMOTE_CLOUD_ENABLED=false
REMOTE_CLOUD_URL=https://api-beta.bondings.ai
REMOTE_MEDIA_PROVIDER=livekit
# 远程真人拨号默认用模组 QVTS；both 同时发送 QVTS 与带内双音。
REMOTE_DTMF_MODE=qvts
# 真人远程通话默认不录音；明确开启后录音也只保存在 Edge 本地。
REMOTE_HUMAN_RECORDING_ENABLED=false
# 仅本地 Tunnel 调试模式使用以下四项；云控制面模式由服务端签发短期媒体凭证。
REMOTE_CONTROL_URL=https://dial.example.com/remote_dialer.html
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# 手机媒体中断超过该秒数后，Edge 自动挂断真实电话。
REMOTE_DISCONNECT_GRACE_SECONDS=5
REMOTE_OUTBOUND_MAX_SECONDS=1800
REMOTE_DIAL_LIMIT_PER_HOUR=10
# Cloudflare Tunnel 只转发到这个独立的最小权限网关，绝不能转发 WEB_PORT。
REMOTE_GATEWAY_PORT=47445
# 配对码有效期与最多配对设备数（内部安全默认值）。
REMOTE_PAIRING_TTL_SECONDS=300
REMOTE_MAX_PAIRED_DEVICES=5
# 单通邀请有效期（隐藏项，允许范围 30-900 秒）。
REMOTE_INVITE_TTL_SECONDS=300
REMOTE_CONNECT_TIMEOUT_SECONDS=45

# ================= 连接管理 =================
# Qwen 连接预热：提前建好 TLS 连接，降低首通接听延迟（默认: true）
QWEN_PREWARM=true
# 通话中断线的最大重连次数（默认: 2）
QWEN_RECONNECT_MAX=2
# OpenAI 通话中断线的最大重连次数（默认: 2）
OPENAI_RECONNECT_MAX=2
